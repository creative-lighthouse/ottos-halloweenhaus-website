<div class="audioplayer" data-soundfile="$SoundFile.Url"<% if $Preload %> data-preload="true"<% end_if %>>
    <span class="audioplayer-button">
        <svg class="playbutton" width="15px" height="15px" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 92.2 122.88" style="enable-background:new 0 0 92.2 122.88" xml:space="preserve"><polygon fill="currentColor" class="st0" points="92.2,60.97 0,122.88 0,0 92.2,60.97"/></svg>
        <svg class="pausebutton" width="15px" height="15px" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 87.72 122.88" style="enable-background:new 0 0 87.72 122.88" xml:space="preserve"><path fill="currentColor" class="st0" d="M0,0h35.54v122.88l-35.54,0V0L0,0z M52.18,0h35.54v122.88l-35.54,0V0L52.18,0z"/></svg>
    </span>
    <span class="audioplayer-rewind">
        <svg xmlns="http://www.w3.org/2000/svg" shape-rendering="geometricPrecision" text-rendering="geometricPrecision" image-rendering="optimizeQuality" fill-rule="evenodd" clip-rule="evenodd" viewBox="0 0 511 510.42"><path fill="currentColor" d="M224.44 293.22c-28.24-25.15-27.48-47.55 0-73.04L450.23 9.54c23.8-19.92 60.85-8.39 60.77 32.19v423.76c-2.66 43.51-39.44 55.73-64.14 35.31L224.44 293.22zm-114.38 216.7H28.18C12.67 509.92 0 497.16 0 481.71V28.94C0 13.52 12.76.76 28.18.76h81.88c15.46 0 28.21 12.67 28.21 28.18v452.77c0 15.54-12.69 28.21-28.21 28.21z"/></svg>
    </span>
    <span class="audioplayer-position">0:00 / 0:00</span>
    <span class="audioplayer-volume">
        <span class="audioplayer-volume-icon" aria-hidden="true">
            <svg width="15px" height="15px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
        </span>
        <span class="audioplayer-volume-popup">
            <input type="range" class="audioplayer-volume-slider" min="0" max="1" step="0.01" value="1" aria-label="Lautstärke">
        </span>
    </span>
</div>
